{
  "name": "restaurant-ordering-system",
  "version": "1.0.0",
  "description": "Full-stack restaurant ordering application",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=backend",
    "start:backend": "npm start --workspace=backend",
    "start:frontend": "npm start --workspace=frontend",
    "build:backend": "npm run build --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "install:all": "npm install && npm install --workspace=backend && npm install --workspace=frontend",
    "create-pos": "npm run create-pos --workspace=backend"
  },
  "keywords": [
    "restaurant",
    "ordering",
    "full-stack"
  ],
  "author": "",
  "license": "ISC"
}
